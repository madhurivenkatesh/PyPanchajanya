          "note": "Case and spaces are ignored"
        },
        {
          "input": "s = \"hello\"",
          "output": "False"
        }
      ],
      "constraints": [
        "0 &le; length of s &le; 10<sup>4</sup>"
      ],
      "starterCode": "def is_palindrome(s):\n    # Return True if s reads the same forwards and backwards,\n    # ignoring case and spaces.\n    pass\n",
      "testCases": [
        {
          "args": [
            "racecar"
          ],
          "expected": true
        },
        {
          "args": [
            "hello"
          ],
          "expected": false
        },
        {
          "args": [
            "A man a plan a canal Panama"
